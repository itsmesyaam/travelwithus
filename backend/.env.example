# Database connection string (SQLite fallback or Neon PostgreSQL link)
# Local development fallback: sqlite:///./travelwithus.db
# Neon PostgreSQL format: postgresql://[user]:[password]@[neon-host]/[db-name]?sslmode=require
DATABASE_URL=postgresql://travelwithus_admin:yourpassword@ep-cool-breeze-123456.us-east-2.aws.neon.tech/travelwithus_db?sslmode=require

# Secret token key for signing JWT authorization payloads
JWT_SECRET=supersecrettravelwithuskey1234567890abcdef

# (Optional) Cloudinary Media Integration Keys
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
